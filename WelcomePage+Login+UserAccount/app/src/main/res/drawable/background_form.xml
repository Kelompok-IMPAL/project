<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="#FFFFFF" /> <!-- White color for the box -->

    <!-- Rounded top corners, no rounding for bottom corners -->
    <corners
        android:topLeftRadius="32dp"
        android:topRightRadius="32dp"
        android:bottomLeftRadius="0dp"
        android:bottomRightRadius="0dp" />

    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp" /> <!-- Optional padding -->
</shape>
